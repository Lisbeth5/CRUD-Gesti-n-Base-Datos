        finally
        {
            guardando = false;
        }
    }

    private void CambiarRolSeleccionado(int rolId, ChangeEventArgs args)
    {
        bool seleccionado = args.Value is bool valor && valor;
        if (seleccionado)
        {
            rolesSeleccionados.Add(rolId);
        }
        else
        {
            rolesSeleccionados.Remove(rolId);
        }
    }

    private HashSet<int> ParsearRolesUsuario(string? rolesTexto)
    {
        if (string.IsNullOrWhiteSpace(rolesTexto))
        {
            return new HashSet<int>();
        }

        var nombres = rolesTexto.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        var ids = roles
            .Where(rol => nombres.Contains(rol.NombreRol ?? "", StringComparer.OrdinalIgnoreCase))
            .Select(rol => rol.RolID);

        return new HashSet<int>(ids);
    }

    private void AbrirCrearRol()
    {
        editandoRol = false;
        rolEditandoId = 0;
        rolForm = new RolRequestModel();
        mostrarModalRol = true;
    }

    private void AbrirEditarRol(RolModel rol)
    {
        editandoRol = true;
        rolEditandoId = rol.RolID;
        rolForm = new RolRequestModel { NombreRol = rol.NombreRol ?? "" };
        mostrarModalRol = true;
    }

    private void CerrarModalRol()
    {
        mostrarModalRol = false;
    }

    private async Task GuardarRol()
    {
        if (string.IsNullOrWhiteSpace(rolForm.NombreRol))
        {
            mensajeError = "El nombre del rol es obligatorio.";
            return;
        }

        guardando = true;
        mensajeError = null;
        mensajeExito = null;

        try
        {
            var respuesta = editandoRol
                ? await Http.PutAsJsonAsync($"api/roles/{rolEditandoId}", rolForm)
                : await Http.PostAsJsonAsync("api/roles", rolForm);

            if (respuesta.IsSuccessStatusCode)
            {
                mensajeExito = editandoRol ? "Rol actualizado correctamente." : "Rol creado correctamente.";
                mostrarModalRol = false;
                await CargarRoles();
                await CargarUsuarios();
            }
            else
            {
                mensajeError = await LeerError(respuesta);
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al guardar rol: {ex.Message}";
        }
        finally
        {
            guardando = false;
        }
    }

    private async Task ConfirmarEliminarRol(RolModel rol)
    {
        bool confirmado = await JS.InvokeAsync<bool>("confirm", $"Desea eliminar el rol {rol.NombreRol}?");
        if (!confirmado)
        {
            return;
        }

        try
        {
            var respuesta = await Http.DeleteAsync($"api/roles/{rol.RolID}");
            if (respuesta.IsSuccessStatusCode)
            {
                mensajeExito = "Rol eliminado correctamente.";
                await CargarRoles();
                await CargarUsuarios();
            }
            else
            {
                mensajeError = await LeerError(respuesta);
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al eliminar rol: {ex.Message}";
        }
    }

    private static IReadOnlyList<string> RolesResumen(string? rolesTexto)
    {
        return RolesOrdenados(rolesTexto).Take(2).ToList();
    }

    private static int CantidadRolesOcultos(string? rolesTexto)
    {
        return Math.Max(0, RolesOrdenados(rolesTexto).Count - 2);
    }

    private static IReadOnlyList<string> RolesOrdenados(string? rolesTexto)
    {
        if (string.IsNullOrWhiteSpace(rolesTexto))
        {
            return Array.Empty<string>();
        }

        return rolesTexto
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderByDescending(EsRolAdministrador)
            .ThenBy(rol => rol, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static bool EsRolAdministrador(string rol)
    {
        return rol.Equals("admin", StringComparison.OrdinalIgnoreCase)
            || rol.Equals("administrador", StringComparison.OrdinalIgnoreCase);
    }

    private static string ClaseEstado(bool activo)
    {
        return activo ? "badge bg-success" : "badge bg-secondary";
    }

    private string ClaseTab(string nombre)
    {
        return vistaActiva == nombre ? "nav-link active fw-bold" : "nav-link";
    }

    private static async Task<string> LeerError(HttpResponseMessage respuesta)
    {
        var contenido = await respuesta.Content.ReadAsStringAsync();
        return string.IsNullOrWhiteSpace(contenido)
            ? $"Error HTTP {(int)respuesta.StatusCode}"
            : contenido;
    }
