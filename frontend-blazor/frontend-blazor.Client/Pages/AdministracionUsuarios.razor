    private async Task GuardarRolesUsuario()
    {
        if (usuarioSeleccionado == null)
        {
            return;
        }

        guardando = true;
        try
        {
            var solicitud = new AsignarRolesModel
            {
                UsuarioID = usuarioSeleccionado.UsuarioID,
                RolesID = rolesSeleccionados.OrderBy(id => id).ToList()
            };
